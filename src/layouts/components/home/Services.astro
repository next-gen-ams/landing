---
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  services: CollectionEntry<"homepage">["data"]["services"];
};

const { services } = Astro.props;
---

<section class="section" id="services">
  <div class="container">
    <div class="flex justify-center mb-12">
      <h2
        set:html={markdownify(services.headline)}
        class="text-3xl tracking-tighter z-1 text-center font-secondary [&>strong]:font-tertiary [&>strong]:tracking-normal [&>strong]:italic [&>strong]:font-normal md:text-3xl lg:text-4xl text-text-light/90 leading-snug text-balance"
        data-aos="fade-up-sm"
      />
    </div>
    <div class="flex flex-col gap-2 items-start">
      <div>
        <img
          src="/images/ams.png"
          class="p-1 glass bg-primary-tint-1 shadow-[0_0_240px_color-mix(in_srgb,var(--color-primary),transparent)] rounded-lg h-auto mx-auto"
        />
        <div class="text-center text-light mt-6 text-sm">
          AMS by Kaleidoscope MT
        </div>
      </div>
      <div class="flex lg:p-6 mt-12 gap-2 lg:flex-row flex-col">
        {
          services.items.map((item: any, index: number) => (
            <div
              class:list={[
                "flex-1 p-6 bg-[color-mix(in_srgb,var(--color-background),black_10%)] z-1 rounded-lg",
              ]}
              data-aos="fade-up-sm"
              data-aos-delay={index * 100}
            >
              <img src="/logo-small.svg" class="size-6 mb-4" />
              <h3
                set:html={markdownify(item.title)}
                class="text-xl lg:text-2xl font-secondary text-text-light mb-8 tracking-tight"
              />
              <p
                set:html={markdownify(item.description)}
                class="leading-relaxed text-base text-light/80"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
